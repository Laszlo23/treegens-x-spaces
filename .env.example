# Copy to `.env` and fill in. Never commit `.env`.
#
# CI (GitHub Actions) uses placeholder public vars for `next build`; see `.github/workflows/ci.yml`.

# Privy — https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=
# Backend JWT verification (optional): https://auth.privy.io/api/v1/apps/<APP_ID>/jwks.json

# Base Sepolia (testnet when `NEXT_PUBLIC_USE_BASE_MAINNET` is not true)
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# Base mainnet — set `true` after deploying with `npm run deploy:base` (uses real ETH)
NEXT_PUBLIC_USE_BASE_MAINNET=false
NEXT_PUBLIC_BASE_MAINNET_RPC=https://mainnet.base.org

# VoiceSeed contract (after `npm run deploy:base-sepolia` or `npm run deploy:base`)
NEXT_PUBLIC_VOICE_SEED_CONTRACT_ADDRESS=

# Site URL for OG / share links (also used server-side for Space API fetch if needed)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- X (Twitter) API v2 — server-only bearer token for Space lookup by id ---
# https://developer.twitter.com/en/docs/twitter-api/spaces/lookup/api-reference/get-spaces-id
# Use any one of these variable names (first match wins). Never NEXT_PUBLIC_*.
# X_API_BEARER_TOKEN=
# TWITTER_BEARER_TOKEN=
# TWITTER_API_BEARER_TOKEN=

# --- Pinata (server-only: IPFS pinning for audio + metadata) ---
# Create a JWT in Pinata: API Keys → JWT with pinning permissions. Paste the token only (no "Bearer " prefix).
# Production (Vercel, etc.): add the same variable in Project Settings → Environment Variables as a server secret.
# Do NOT use NEXT_PUBLIC_ for this value.
PINATA_JWT=

# Optional: gateway for resolving CIDs in the UI
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# Optional: deployment block to narrow event scans (faster RPC)
NEXT_PUBLIC_VOICE_SEED_FROM_BLOCK=0

# Hardhat deploy (local only, never commit real keys)
DEPLOYER_PRIVATE_KEY=
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Base mainnet deploy (use `npm run deploy:base`) — requires ETH on Base for gas
BASE_MAINNET_RPC_URL=https://mainnet.base.org
